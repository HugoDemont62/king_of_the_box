@using Sandbox
@using Sandbox.UI
@using System
@using System.Linq
@inherits PanelComponent

<root>
	@if ( LocalPlayer != null && LocalPlayer.Team != KobTeam.None )
	{
		<div class="hud-team-frame" style="border-color: @GetTeamColor();"></div>
	}

	@if ( Manager != null )
	{
		<div class="arma-scoreboard">
			<div class="arma-score-box team-red-bg">
				<span class="arma-score-value">@Manager.ScoreRed</span>
			</div>
			<div class="arma-score-box team-blue-bg">
				<span class="arma-score-value">@Manager.ScoreBlue</span>
			</div>
			<div class="arma-score-box team-green-bg">
				<span class="arma-score-value">@Manager.ScoreGreen</span>
			</div>
		</div>
	}

	@if ( LocalHealth != null && LocalPlayer?.Team != KobTeam.None && !LocalHealth.IsDead )
	{
		<div class="kob-combat-hud">
			<div class="kob-stat-row">
				<span class="kob-stat-label">❤</span>
				<div class="kob-bar kob-health-bar">
					<div class="kob-bar-fill kob-health-fill"
					     style="width: @(LocalHealth.MaxHealth > 0 ? (int)(LocalHealth.Health / LocalHealth.MaxHealth * 100) : 0)%;"></div>
				</div>
				<span class="kob-stat-value">@((int)LocalHealth.Health)</span>
			</div>
			<div class="kob-stat-row">
				<span class="kob-stat-label">🛡</span>
				<div class="kob-bar kob-armor-bar">
					<div class="kob-bar-fill kob-armor-fill"
					     style="width: @(LocalHealth.MaxArmor > 0 ? (int)(LocalHealth.Armor / LocalHealth.MaxArmor * 100) : 0)%;"></div>
				</div>
				<span class="kob-stat-value">@((int)LocalHealth.Armor)</span>
			</div>
		</div>

		@if ( ActiveWeapon != null )
		{
			<div class="kob-weapon-panel">
				<div class="kob-weapon-name">@ActiveWeapon.WeaponName</div>
				<div class="kob-weapon-ammo-row">
					<span class="kob-ammo-current">@ActiveWeapon.AmmoCurrent</span>
					<span class="kob-ammo-sep"> / </span>
					<span class="kob-ammo-max">@ActiveWeapon.AmmoMax</span>
				</div>
				@if ( ActiveWeapon.IsReloading )
				{
					<div class="kob-reload-bar-bg">
						<div class="kob-reload-bar-fill" style="width: @ReloadPct(ActiveWeapon)%;"></div>
					</div>
				}
			</div>
		}
	}

	<div class="kob-crosshair">+</div>

	@if ( Manager?.GameOver == true )
	{
		<div class="kob-gameover-overlay">
			<div class="kob-go-winner" style="color: @WinnerColor();">
				ÉQUIPE @WinnerLabel() GAGNE !
			</div>
			<div class="kob-go-scoreboard">
				@foreach ( var entry in TeamGroups() )
				{
					bool isWinner = entry.Item1 == Manager.WinnerTeam;
					<div class="kob-sb-team-block @(isWinner ? "kob-sb-team-winner" : "")">
						<div class="kob-sb-team-hdr" style="background: @TeamGradient(entry.Item1); border-left-color: @TeamBadgeColor(entry.Item1);">
							<span class="kob-sb-team-hdr-name">@TeamLabel(entry.Item1)</span>
							<div class="kob-sb-team-hdr-right">
								<div class="kob-sb-team-hdr-prog-bg">
									<div class="kob-sb-team-hdr-prog-fill" style="width: @ScorePct(entry.Item3)%; background: @TeamBadgeColor(entry.Item1);"></div>
								</div>
								<span class="kob-sb-team-hdr-score">@entry.Item3 <span class="kob-sb-team-hdr-max">/ @(Manager?.ScoreToWin ?? 200)</span></span>
							</div>
						</div>
						<div class="kob-sb-cols">
							<span class="col-rank">#</span>
							<span class="col-player">JOUEUR</span>
							<span class="col-zone">ZONE</span>
							<span class="col-k">K</span>
							<span class="col-d">M</span>
							<span class="col-a">A</span>
							<span class="col-kd">K/D</span>
							<span class="col-ping">PING</span>
						</div>
						@if ( entry.Item2.Count == 0 )
						{
							<div class="kob-sb-empty">Aucun joueur</div>
						}
						@foreach ( var player in entry.Item2 )
						{
							int  globalRank = _sortedPlayers.IndexOf( player ) + 1;
							bool isLocal    = !player.IsProxy;
							<div class="kob-sb-row @(isLocal ? "kob-sb-row-local" : "")">
								<span class="col-rank @(globalRank == 1 ? "kob-sb-rank-gold" : "")">@("#" + globalRank)</span>
								<span class="col-player" style="color: @ScoreboardTeamColor(player.Team);">@player.PlayerName</span>
								<span class="col-zone" style="color: @TeamBadgeColor(player.Team);">@player.ZonePoints</span>
								<span class="col-k">@player.Kills</span>
								<span class="col-d">@player.Deaths</span>
								<span class="col-a">@player.Assists</span>
								<span class="col-kd">@KdRatio(player)</span>
								<span class="col-ping @PingClass(player.Ping)">@(player.Ping)ms</span>
							</div>
						}
					</div>
				}
			</div>
			<div class="kob-go-countdown">
				Nouvelle partie dans @((int)MathF.Ceiling( Manager.ResetCountdown ))s
			</div>
		</div>
	}

	@if ( LocalRespawn != null && LocalRespawn.IsDead )
	{
		<div class="kob-death-overlay">
			<div class="kob-death-title">ÉLIMINÉ</div>
			<div class="kob-death-killer">par <b>@(string.IsNullOrEmpty(LocalRespawn.KillerName) ? "l'environnement" : LocalRespawn.KillerName)</b></div>
			<div class="kob-death-timer">Respawn dans @(MathF.Ceiling( LocalRespawn.RespawnTimer ))s</div>
		</div>
	}

	@if ( ShowScoreboard )
	{
		<div class="kob-scoreboard">
			<div class="kob-sb-title-bar">KING OF THE BOX</div>
			@foreach ( var entry in TeamGroups() )
			{
				<div class="kob-sb-team-block">
					<div class="kob-sb-team-hdr" style="background: @TeamGradient(entry.Item1); border-left-color: @TeamBadgeColor(entry.Item1);">
						<span class="kob-sb-team-hdr-name">@TeamLabel(entry.Item1)</span>
						<div class="kob-sb-team-hdr-right">
							<div class="kob-sb-team-hdr-prog-bg">
								<div class="kob-sb-team-hdr-prog-fill" style="width: @ScorePct(entry.Item3)%; background: @TeamBadgeColor(entry.Item1);"></div>
							</div>
							<span class="kob-sb-team-hdr-score">@entry.Item3 <span class="kob-sb-team-hdr-max">/ @(Manager?.ScoreToWin ?? 200)</span></span>
						</div>
					</div>
					<div class="kob-sb-cols">
						<span class="col-rank">#</span>
						<span class="col-player">JOUEUR</span>
						<span class="col-zone">ZONE</span>
						<span class="col-k">K</span>
						<span class="col-d">M</span>
						<span class="col-a">A</span>
						<span class="col-kd">K/D</span>
						<span class="col-ping">PING</span>
					</div>
					@if ( entry.Item2.Count == 0 )
					{
						<div class="kob-sb-empty">Aucun joueur</div>
					}
					@foreach ( var player in entry.Item2 )
					{
						int  globalRank = _sortedPlayers.IndexOf( player ) + 1;
						bool isLocal    = !player.IsProxy;
						<div class="kob-sb-row @(isLocal ? "kob-sb-row-local" : "")">
							<span class="col-rank @(globalRank == 1 ? "kob-sb-rank-gold" : "")">@("#" + globalRank)</span>
							<span class="col-player" style="color: @ScoreboardTeamColor(player.Team);">@player.PlayerName</span>
							<span class="col-zone" style="color: @TeamBadgeColor(player.Team);">@player.ZonePoints</span>
							<span class="col-k">@player.Kills</span>
							<span class="col-d">@player.Deaths</span>
							<span class="col-a">@player.Assists</span>
							<span class="col-kd">@KdRatio(player)</span>
							<span class="col-ping @PingClass(player.Ping)">@(player.Ping)ms</span>
						</div>
					}
				</div>
			}
		</div>
	}
</root>

@code {
	KobPlayer            LocalPlayer  => Scene.GetAllComponents<KobPlayer>().FirstOrDefault( p => !p.IsProxy );
	KobManager           Manager      => KobManager.Instance;
	KobHealth            LocalHealth  => LocalPlayer?.Components.Get<KobHealth>();
	KobRespawnController LocalRespawn => LocalPlayer?.Components.Get<KobRespawnController>();
	KobWeapon            ActiveWeapon => LocalPlayer?.Components.GetAll<KobWeapon>( FindMode.EverythingInSelfAndDescendants )
	                                         .OrderBy( w => w.WeaponSlot )
	                                         .ElementAtOrDefault( LocalPlayer.ActiveWeaponSlot );

	bool            ShowScoreboard { get; set; }
	List<KobPlayer> _sortedPlayers = new();
	List<KobPlayer> _redPlayers    = new();
	List<KobPlayer> _bluePlayers   = new();
	List<KobPlayer> _greenPlayers  = new();

	int ReloadPct( KobWeapon w ) =>
		(int)( MathF.Min( 1f, MathF.Max( 0f, ( Time.Now - w.ReloadStartTime ) / w.ReloadTime ) ) * 100f );

	int    TotalScore( KobPlayer p ) => p.Kills + p.Assists + p.ZonePoints;
	string KdRatio( KobPlayer p )    => ( p.Kills / (float)System.Math.Max( p.Deaths, 1 ) ).ToString( "F2" );
	string PingClass( int ping )     => ping < 60 ? "ping-green" : ping < 120 ? "ping-orange" : "ping-red";
	int    ScorePct( int score )     => System.Math.Min( score * 100 / System.Math.Max( Manager?.ScoreToWin ?? 200, 1 ), 100 );

	(KobTeam, List<KobPlayer>, int)[] TeamGroups() => new[]
	{
		(KobTeam.Red,   _redPlayers,   Manager?.ScoreRed   ?? 0),
		(KobTeam.Blue,  _bluePlayers,  Manager?.ScoreBlue  ?? 0),
		(KobTeam.Green, _greenPlayers, Manager?.ScoreGreen ?? 0),
	};

	string TeamLabel( KobTeam team ) => team switch
	{
		KobTeam.Red   => "ÉQUIPE ROUGE",
		KobTeam.Blue  => "ÉQUIPE BLEUE",
		KobTeam.Green => "ÉQUIPE VERTE",
		_             => "SANS ÉQUIPE",
	};

	string TeamGradient( KobTeam team ) => team switch
	{
		KobTeam.Red   => "linear-gradient(90deg, rgba(200,40,40,0.35) 0%, rgba(0,0,0,0) 100%)",
		KobTeam.Blue  => "linear-gradient(90deg, rgba(40,80,210,0.35) 0%, rgba(0,0,0,0) 100%)",
		KobTeam.Green => "linear-gradient(90deg, rgba(40,170,40,0.35) 0%, rgba(0,0,0,0) 100%)",
		_             => "none",
	};

	string WinnerColor() => ( Manager?.WinnerTeam ?? KobTeam.None ) switch
	{
		KobTeam.Red   => "#ff4444",
		KobTeam.Blue  => "#4488ff",
		KobTeam.Green => "#44cc44",
		_             => "white",
	};

	string WinnerLabel() => ( Manager?.WinnerTeam ?? KobTeam.None ) switch
	{
		KobTeam.Red   => "ROUGE",
		KobTeam.Blue  => "BLEUE",
		KobTeam.Green => "VERTE",
		_             => "?",
	};

	string GetTeamColor() => ( LocalPlayer?.Team ?? KobTeam.None ) switch
	{
		KobTeam.Red   => "#ff4444",
		KobTeam.Blue  => "#4488ff",
		KobTeam.Green => "#44cc44",
		_             => "white",
	};

	string TeamBadgeColor( KobTeam team ) => team switch
	{
		KobTeam.Red   => "#ff4444",
		KobTeam.Blue  => "#4488ff",
		KobTeam.Green => "#44cc44",
		_             => "#888888",
	};

	string ScoreboardTeamColor( KobTeam team ) => team switch
	{
		KobTeam.Red   => "#ff6666",
		KobTeam.Blue  => "#6699ff",
		KobTeam.Green => "#66dd66",
		_             => "#cccccc",
	};

	protected override void OnUpdate()
	{
		var show = Input.Down( "score" );
		if ( ShowScoreboard == show ) return;
		ShowScoreboard = show;
		StateHasChanged();
	}

	protected override int BuildHash()
	{
		var h       = new System.HashCode();
		var player  = LocalPlayer;
		var health  = player?.Components.Get<KobHealth>();
		var respawn = player?.Components.Get<KobRespawnController>();
		var weapon  = player?.Components.GetAll<KobWeapon>( FindMode.EverythingInSelfAndDescendants )
		                    .OrderBy( w => w.WeaponSlot )
		                    .ElementAtOrDefault( player.ActiveWeaponSlot );

		h.Add( player?.Team );
		h.Add( player is not null );
		h.Add( Manager?.ScoreRed );
		h.Add( Manager?.ScoreBlue );
		h.Add( Manager?.ScoreGreen );
		h.Add( Manager?.PlayersRed );
		h.Add( Manager?.PlayersBlue );
		h.Add( Manager?.PlayersGreen );
		h.Add( health?.Health );
		h.Add( health?.Armor );
		h.Add( health?.IsDead );
		h.Add( respawn?.IsDead );
		h.Add( (int)MathF.Ceiling( respawn?.RespawnTimer ?? 0f ) );
		h.Add( respawn?.KillerName );
		h.Add( weapon?.AmmoCurrent );
		h.Add( weapon?.IsReloading );
		h.Add( weapon?.WeaponName );
		h.Add( weapon is { IsReloading: true } ? ReloadPct( weapon ) : 0 );
		h.Add( player?.ActiveWeaponSlot );
		h.Add( Manager?.GameOver );
		h.Add( Manager?.WinnerTeam );
		h.Add( (int)MathF.Ceiling( Manager?.ResetCountdown ?? 0f ) );

		if ( ShowScoreboard || Manager?.GameOver == true )
		{
			var all    = Scene.GetAllComponents<KobPlayer>().ToList();
			_sortedPlayers = all.OrderByDescending( p => TotalScore( p ) ).ThenByDescending( p => p.Kills ).ToList();
			_redPlayers    = all.Where( p => p.Team == KobTeam.Red   ).OrderByDescending( p => TotalScore( p ) ).ToList();
			_bluePlayers   = all.Where( p => p.Team == KobTeam.Blue  ).OrderByDescending( p => TotalScore( p ) ).ToList();
			_greenPlayers  = all.Where( p => p.Team == KobTeam.Green ).OrderByDescending( p => TotalScore( p ) ).ToList();

			foreach ( var p in _sortedPlayers )
			{
				h.Add( p.Kills );
				h.Add( p.Deaths );
				h.Add( p.Assists );
				h.Add( p.ZonePoints );
				h.Add( (int)p.TimePlayed );
				h.Add( p.Ping );
				h.Add( p.Team );
				h.Add( p.PlayerName );
			}
		}

		return h.ToHashCode();
	}
}
